<?xml version="1.0" encoding="utf-8"?>
<!-- item_medicine.xml – reusable medicine row -->
<!-- Usage: bind data in RecyclerView Adapter or set fields manually via findViewById after <include> -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!--
            Status circle icon.
            Change background drawable + text based on status:
              taken   → bg_circle_taken   (green light)  text "✓"  textColor #2E7D47
              missed  → bg_circle_missed  (red light)    text "✕"  textColor #C04030
              pending → bg_circle_pending (gray light)   text "○"  textColor #CCCCCC
        -->
        <TextView
            android:id="@+id/medStatus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✓"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2E7D47"
            android:gravity="center"
            android:background="@drawable/bg_circle_taken" />

        <!-- Medicine name + description -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/medName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metoprolol"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="#222222" />

            <TextView
                android:id="@+id/medDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25mg · Heart Rate"
                android:textSize="15sp"
                android:textColor="#BBBBBB"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Time -->
        <TextView
            android:id="@+id/medTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6:00 AM"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#AAAAAA" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
