<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F3"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="28dp"
        android:paddingBottom="40dp">

        <!-- ── HEADER ── -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good Morning 👋"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#222222" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monday, 23 Feb 2026"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#AAAAAA"
            android:layout_marginTop="5dp" />

        <!-- ── SECTION LABEL: Patient ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PATIENT"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#CCCCCC"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <!-- ── PATIENT CARD ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <!-- Avatar -->
                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="👴"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_green_light" />

                <!-- Name + Meta -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Harold Whitmore"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age 78 · Blood O+ · Dr. Sandra Lee"
                        android:textSize="15sp"
                        android:textColor="#AAAAAA"
                        android:textStyle="bold"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <!-- Stats -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="63%"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D47" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── TALKBACK TOGGLE (ADDED) ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔊 Voice Alerts (TalkBack)"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_talkback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── SECTION LABEL: Progress ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROGRESS"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#CCCCCC"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <!-- ── PIE / PROGRESS CARD ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <!-- Donut chart placeholder -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <!-- Replace with a custom DonutChartView or MPAndroidChart -->
                    <com.example.medicinereminder.DonutChartView
                        android:id="@+id/donutChart"
                        android:layout_width="100dp"
                        android:layout_height="100dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="63%"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#222222" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DONE"
                            android:textSize="10sp"
                            android:textColor="#CCCCCC"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="20dp">

                    <!-- Taken -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot_green"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Taken"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#222222" />
                    </LinearLayout>

                    <!-- Missed -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot_red"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Missed"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#222222" />
                    </LinearLayout>

                    <!-- Upcoming -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot_gray"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Upcoming"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#222222" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── SECTION LABEL: Next Medicine ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEXT MEDICINE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#CCCCCC"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <!-- ── NEXT MEDICINE CARD ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#2E7D47">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DUE TODAY"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#80FFFFFF"
                    android:letterSpacing="0.15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Furosemide"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="40mg · With evening meal"
                    android:textSize="15sp"
                    android:textColor="#B3FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6:00 PM"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_next_time_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── SECTION LABEL: Medicines ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEDICINES"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#CCCCCC"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <!-- ── MEDICINE ROWS ── -->

        <!-- Metoprolol – Taken -->
        <include layout="@layout/item_medicine"
            android:id="@+id/medMetoprolol" />

        <!-- Aspirin – Taken -->
        <include layout="@layout/item_medicine"
            android:id="@+id/medAspirin" />

        <!-- Lisinopril – Taken -->
        <include layout="@layout/item_medicine"
            android:id="@+id/medLisinopril" />

        <!-- Metformin – Taken -->
        <include layout="@layout/item_medicine"
            android:id="@+id/medMetformin" />

        <!-- Vitamin D3 – Taken -->
        <include layout="@layout/item_medicine"
            android:id="@+id/medVitaminD3" />

        <!-- Atorvastatin – Missed -->
        <include layout="@layout/item_medicine"
            android:id="@+id/medAtorvastatin" />

        <!-- Furosemide – Pending -->
        <include layout="@layout/item_medicine"
            android:id="@+id/medFurosemide" />

        <!-- Melatonin – Pending -->
        <include layout="@layout/item_medicine"
            android:id="@+id/medMelatonin" />

        <!-- ── SECTION LABEL: Need Help? ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEED HELP?"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#CCCCCC"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <!-- ── CALL CARD ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <!-- Doctor avatar -->
                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="👩‍⚕️"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_green_xlight" />

                <!-- Doctor info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Sandra Lee"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your doctor"
                        android:textSize="15sp"
                        android:textColor="#AAAAAA"
                        android:textStyle="bold"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <!-- Call button -->
                <Button
                    android:id="@+id/btnCall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 Call"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2A6E42"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    app:cornerRadius="14dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
